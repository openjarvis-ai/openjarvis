# Turso Database
# For local development without Turso, use a local SQLite file (default):
# TURSO_DATABASE_URL=file:./data/local.db
# TURSO_AUTH_TOKEN=

# For production with Turso:
# TURSO_DATABASE_URL=libsql://your-database.turso.io
# TURSO_AUTH_TOKEN=your-auth-token

# Opus API Configuration
# Get your service key from: https://developer.opus.com
OPUS_SERVICE_KEY=your_opus_service_key_here
